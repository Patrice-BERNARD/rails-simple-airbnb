<div class="card" style="width: 18rem;">
  <div class="card-body">
    <img src="https://picsum.photos/100/100" class="card-img-top rounded" alt="...">
    <h5 class="card-title"> <%= flat.name %></h5>
    <h6 class="card-subtitle mb-2 text-body-secondary"> <%= flat.address %></h6>
    <p class="card-text"> <%= flat.description %></p>
    <i class="fa-solid fa-people-line"></i>  <%= flat.number_of_guests %>
    <i class="fa-solid fa-euro-sign"></i> <%= flat.price_per_night %>
    <div class="links d-flex gap-2">
        <%= link_to "More info", flat_path(flat) %>
        <a href="#" class="card-link link-warning">Edit</a>
        <a href="#" class="card-link link-danger">Remove</a>

    </div>
  </div>
</div>
